{
  "name": "maison-chance-volunteer-management",
  "version": "0.1.0",
  "description": "Hệ thống quản lý hoạt động tình nguyện Maison Chance — Desktop App",
  "private": true,
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "smoke:ui": "node tools/smoke-ui.mjs",
    "smoke:electron": "electron tools/smoke-electron.mjs",
    "preview": "vite preview",
    "start:backend": "cd backend && npm start",
    "start:electron": "wait-on tcp:127.0.0.1:5173 tcp:127.0.0.1:3000 && electron . --dev",
    "dev:desktop": "concurrently \"npm run start:backend\" \"npm run dev\" \"npm run start:electron\""
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "react": "^18.3.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "vite": "^5.4.0",
    "wait-on": "^9.0.10"
  }
}
